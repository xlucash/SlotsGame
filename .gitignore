# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out
*.tsbuildinfo

# Node
/node_modules
npm-debug.log*
yarn-error.log
yarn-debug.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example
*.local

# Local Firebase env file — generated from secrets in CI, hand-rolled
# locally. Template at src/environments/environment.template.ts is the
# committed source-of-shape.
/src/environments/environment.ts

# Angular cache
/.angular

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# Miscellaneous
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# System files
.DS_Store
Thumbs.db

# Claude / AI assistant artefacts (project-local)
/.claude
